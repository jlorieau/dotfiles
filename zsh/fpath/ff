emulate -L zsh

command=()

case $1 in
bluray)
    command+=(ffmeg -stats)
    command+=(-i $2 -map 0)
    command+=(-c:v libx265 -crf 20 -preset medium)
    command+=(-c:a aac -b:a 320k)
    command+=(-c:s copy)
    command+=(${3%.*}.mkv)
    ;;
*)
    echo "Valid subcommands: bluray, bluray2pass"
    return
    ;;
esac

echo ${command[*]}
eval ${command[*]}

